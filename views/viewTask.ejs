<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Your Tasks</title>
</head>
<style>
    /* Default Closed Accordion Button Styling */
    .accordion-button {
        background-color: #b3d9ff;
        border: none;
        border-radius: 0;
        box-shadow: none;
    }

    /* Active Expanded Accordion Button Styling */
    .accordion-button:not(.collapsed) {
        background-color: #b3d9ff;
    }

    .accordion-body {
        background-color: #f8f9fa;
    }

    /* Clean up halo outline click frames */
    .accordion-button:focus {
        box-shadow: none !important;
    }
</style>

<body>
    <%- include('partials/navbar') %>
    <div class="container mt-4">
        <h1 class="text-center mb-4">Your Tasks</h1>

        <% if (tasks.length === 0) { %>
            <div class="text-center" role="alert">
                No tasks found. <a href="/tasks" class="alert-link">Add a new task</a> to get started!
            </div>
        <% } else { %>

            <div class="accordion container mt-4" id="taskAccordion">
                <% tasks.forEach(function(task, index) { %>

                    <% if (!task.isCompleted) { %>

                        <div class="accordion-item mb-3 shadow-sm border rounded" style="overflow: hidden;">

                            <h2 class="accordion-header" id="heading-<%= index %>">
                                <button class="accordion-button collapsed text-dark py-3" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapse-<%= index %>"
                                    aria-expanded="false" aria-controls="collapse-<%= index %>">

                                    <div class="d-flex flex-column align-items-start text-start">
                                        <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
                                            <span class="fs-5 fw-bold text-dark">
                                                <%= task.taskName %>
                                            </span>

                                            <% if (task.taskCategory) { %>
                                                <span class="badge bg-secondary font-monospace small" style="font-size: 11px;">
                                                    [<%= task.taskCategory %>]
                                                </span>
                                            <% } %>
                                        </div>

                                        <span class="text-muted small fw-semibold">
                                            Due: <%= new Date(task.taskdeadline).toLocaleDateString() %>
                                        </span>
                                    </div>

                                </button>
                            </h2>

                            <div id="collapse-<%= index %>" class="accordion-collapse collapse"
                                aria-labelledby="heading-<%= index %>" data-bs-parent="#taskAccordion">
                                
                                <div class="accordion-body bg-light-subtle border-top py-3 d-flex flex-column align-items-stretch">

                                    <p class="d-flex align-items-center flex-wrap gap-2 mb-1"> 
                                        <%= task.description || 'No details provided.' %>
                                    </p>

                                    <div class="d-flex justify-content-between align-items-center pt-2 mt-3">

                                        <div class="d-flex gap-2">
                                            <a href="/tasks/<%= task.id %>/edit"
                                                class="btn btn-outline-dark btn-sm d-flex align-items-center justify-content-center"
                                                style="width: 32px; height: 32px;" title="Edit Task">
                                                ✏️
                                            </a>

                                            <form action="/tasks/<%= task.id %>/delete" method="POST" class="m-0"
                                                onsubmit="return confirm('Delete this tracking entry permanent record?')">
                                                <button type="submit" class="btn btn-danger btn-sm d-flex align-items-center justify-content-center"
                                                    style="width: 32px; height: 32px;" title="Delete Task">
                                                    🗑️
                                                </button>
                                            </form>
                                        </div>

                                        <div>
                                            <form action="/tasks/<%= task.id %>/complete" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-success btn-sm d-flex align-items-center justify-content-center"
                                                    style="width: 32px; height: 32px;" title="Mark Complete">
                                                    ✓
                                                </button>
                                            </form>
                                        </div>

                                    </div> </div> </div> </div> <% } %> 
                <% }); %>
            </div>

        <% } %>
    </div>
</body>

</html>