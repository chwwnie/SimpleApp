<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>View Task</title>
</head>
<style>
    .accordion-button {
        background-color: #b3d9ff;
        border: none;
        border-radius: 0;
        box-shadow: none;
    }
    
    .accordion-button:not(.collapsed) {
        background-color: #b3d9ff;
    }
    
    .accordion-body {
        background-color: #f8f9fa;
    }
</style>
<body>
    <%- include('partials/navbar') %>
    <div class="container mt-4">
        <h1 class="text-center mb-4">Your Tasks</h1>
        
        <div class="accordion container mt-4" id="taskAccordion">
    <% tasks.forEach(function(task, index) { %> 
        
        <div class="accordion-item mb-3 shadow-sm border rounded" style="overflow: hidden;">
            
            <h2 class="accordion-header" id="heading-<%= index %>">
                <button class="accordion-button collapsed text-dark py-3" type="button" 
                        data-bs-toggle="collapse" data-bs-target="#collapse-<%= index %>" 
                        aria-expanded="false" aria-controls="collapse-<%= index %>">
                    
                    <div class="d-flex flex-column align-items-start text-start">
                        <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
                            <span class="fs-5 fw-bold text-dark"><%= task.taskName %></span>
                            
                            <span class="badge bg-secondary font-monospace small" style="font-size: 11px;">
                                <%= task.taskCategory%>
                            </span>
                        </div>
                        
                        <span class="text-muted small fw-semibold">
                            Due: <%= new Date(task.taskdeadline).toLocaleDateString() %>
                        </span>
                    </div>

                </button>
            </h2>

            <div id="collapse-<%= index %>" class="accordion-collapse collapse" 
                 aria-labelledby="heading-<%= index %>" data-bs-parent="#taskAccordion">
                <div class="accordion-body bg-light-subtle border-top py-3">
                    
                    <p class="mb-0 text-secondary" style="font-family: Verdana, sans-serif; font-size: 14px; line-height: 1.5;">
                        <%= task.description || ' ' %>
                    </p>

                </div>
            </div>

        </div>

    <% }); %>
</div>
</body>
</html>