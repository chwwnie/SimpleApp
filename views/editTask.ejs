<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Edit Task</title>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container mt-4">
        <h1 class="text-center mb-4">Edit Task</h1>
        <form action="/tasks/<%= task.id %>/edit" method="POST" class="card p-4 max auto card-float">  
            <div class="mb-3">
                <label for="title" class="form-label">Task Title</label>
                <input type="text" class="form-control" id="title" name="taskName" value="<%= task.taskName %>" required>
            </div>

            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select class="form-select" id="category" name="taskCategory">
                    <option value="">Select category</option>
                    <option value="Exam" <%= task.taskCategory === 'Exam' ? 'selected' : '' %>>Exam</option>
                    <option value="Project" <%= task.taskCategory === 'Project' ? 'selected' : '' %>>Project</option>
                    <option value="Homework" <%= task.taskCategory === 'Homework' ? 'selected' : '' %>>Homework</option>
                    <option value="Uncategorized" <%= task.taskCategory === 'Uncategorized' ? 'selected' : '' %>>Other</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" id="description" name="description" rows="3"><%= task.description %></textarea>
            </div>

            <div class="mb-3">
                <label for="deadline" class="form-label">Deadline</label>
                <input type="datetime-local" class="form-control" id="deadline" name="taskdeadline" value="<%= new Date(task.taskdeadline).toISOString().slice(0,16) %>" required>
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
    </div>
</body>
</html>