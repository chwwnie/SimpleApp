<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>DeadlineBuddy</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/navbar') %>

        <div class="container mt-4">
            <div class="card p-4 max auto card-float">
                <h1 class="text-center">Welcome to DeadlineBuddy!</h1>
            </div>
            <br>
            <div class="row justify-content-center mb-4">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="card shadow-sm bg-white">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex align-items-center justify-content-around text-center">

                                <div class="p-2">
                                    <span class="badge bg-success d-block small fw-bold text-uppercase"
                                        style="letter-spacing: 0.5px;">Completed</span>
                                    <div class="d-inline-flex align-items-center justify-content-center mt-1">
                                        <span class="stat-dot bg-success me-2"></span>
                                        <span class="fs-5 fw-bold text-dark">5</span>
                                    </div>
                                </div>

                                <div class="vr my-2 text-black-50" style="height: 50px;"></div>

                                <div class="p-2">
                                    <span class="badge bg-warning d-block small fw-bold text-uppercase"
                                        style="letter-spacing: 0.5px;">In-Progress</span>
                                    <div class="d-inline-flex align-items-center justify-content-center mt-1">
                                        <span class="stat-dot bg-warning me-2"></span>
                                        <span class="fs-5 fw-bold text-dark">3</span>
                                    </div>
                                </div>

                                <div class="vr my-2 text-black-50" style="height: 50px;"></div>

                                <div class="p-2">
                                    <span class="badge bg-danger d-block small fw-bold text-uppercase"
                                        style="letter-spacing: 0.5px;">Overdue</span>
                                    <div class="d-inline-flex align-items-center justify-content-center mt-1">
                                        <span class="stat-dot bg-danger me-2"></span>
                                        <span class="fs-5 fw-bold text-dark text-danger">1</span>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm p-4 max auto card-float">
                <h2 class="text-center">Urgent Deadlines</h2>
                <div class="list-group mt-3">
                    <% if (tasks.length === 0) { %>
                        <br>
                        <p class="text-center text-muted">No pending deadlines! You can relax a little B)</p>
                    <% } else { %>
                        <% tasks.forEach(task => { %>
                            <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-1"><%= task.title %><%= task.category ? ` (${task.category})` : '' %></h5>
                                    <small class="text-muted">Due: <%= task.dueDate %></small>
                                </div>
                            </a>
                        <% }); %>
                    <% } %>
                </div>
            </div>

        </div>


</body>

</html>